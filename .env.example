# --- Auth (required — NextAuth returns 500 / error=Configuration without these) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Optional on Vercel (falls back to VERCEL_URL); required for local/self-hosted
NEXTAUTH_URL=http://localhost:3000

# Google OAuth ("Continue with Google"). Redirect URI must be allowed in Google
# Cloud console: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (required — Prisma adapter, credentials login, usage tracking) ---
DATABASE_URL=postgresql://user:password@localhost:5432/noeron

# --- Domains ---
ROOT_DOMAIN=mydomain.com
NEXT_PUBLIC_ROOT_DOMAIN=mydomain.com
PLATFORM_APP_HOST=app.mydomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Website scraping (required for URL import) ---
FIRECRAWL_API_KEY=

# --- AI providers (at least one required) ---
AI_GATEWAY_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# Optional: Morph for faster edits
MORPH_API_KEY=
# Required to store user-supplied AI keys (BYO-key vault). 32 bytes as 64 hex
# chars or 32-byte base64. Generate: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=

# --- Sandbox provider: 'vercel', 'e2b', or 'vps' ---
SANDBOX_PROVIDER=vercel
# Vercel sandbox auth — Method A: OIDC (vercel link && vercel env pull)
VERCEL_OIDC_TOKEN=
# Method B: Personal Access Token
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_API_TOKEN=
# E2B (if SANDBOX_PROVIDER=e2b)
E2B_API_KEY=
# VPS (if SANDBOX_PROVIDER=vps)
# HTTP endpoint of the vps-agent service (must be reachable from the Next.js app)
VPS_AGENT_URL=https://vps-agent.internal:4000
# Shared secret used to sign app->agent requests
VPS_AGENT_TOKEN=
# Public IP of the VPS (used for DNS verification of custom domains)
VPS_PUBLIC_IP=
# Base domain for sandbox preview subdomains (defaults to NEXT_PUBLIC_ROOT_DOMAIN)
VPS_BASE_DOMAIN=
# Port the dev server listens on inside sandbox containers
VPS_SANDBOX_DEV_PORT=3000
# Enable static-site deployments to the VPS even when SANDBOX_PROVIDER is not vps
VPS_DEPLOYMENTS_ENABLED=false

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
