generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  password           String? // Hashed password for credential provider
  role               String              @default("user") // "user" | "admin"
  accounts           Account[]
  sessions           Session[]
  subscription       Subscription?
  usage              Usage?
  generations        Generation[]
  generationSessions GenerationSession[]
  sites              Site[]
  aiCredentials      AiCredential[]
  githubConnections  GitHubConnection[]
  createdAt          DateTime            @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("inactive") // active, canceled, past_due, trialing
  tier                 String    @default("free") // free, pro, team
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {
  id               String   @id @default(cuid())
  userId           String   @unique
  generationsUsed  Int      @default(0) // legacy column name; stores tokens used this month
  generationsLimit Int      @default(50000) // legacy column name; stores monthly token limit
  resetDate        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Generation {
  id        String   @id @default(cuid())
  userId    String
  url       String?
  style     String?
  status    String   @default("pending") // pending, completed, failed
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GenerationSession {
  id                   String   @id @default(cuid())
  userId               String
  siteId               String?
  sandboxId            String   @unique
  sandboxProvider      String   @default("vps")
  sandboxUrl           String?
  rawSandboxUrl        String?
  sandboxName          String?  @unique
  sandboxRuntimeStatus String?
  currentSnapshotId    String?
  /** VPS container identifier when using the vps provider. */
  sandboxContainerId   String?
  /** VPS host:port for direct container access when using the vps provider. */
  sandboxHost          String?
  status               String   @default("creating")
  chatMessages         Json     @default("[]")
  conversationCtx      Json?
  aiModel              String?
  fileCache            Json     @default("{}")
  existingFiles        String[]
  viteErrors           Json     @default("[]")
  lastActiveAt         DateTime @default(now())
  expiresAt            DateTime @default(dbgenerated("(now() + '24:00:00'::interval)"))
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site                 Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([userId, lastActiveAt])
  @@index([siteId, lastActiveAt])
}

model Site {
  id                   String              @id @default(cuid())
  userId               String
  name                 String
  slug                 String              @unique
  subdomain            String              @unique
  customDomain         String?             @unique
  customDomainVerified Boolean             @default(false)
  domainVerificationToken String?
  domainStatus         String              @default("unconfigured")
  published            Boolean             @default(false)
  lastPublishedAt      DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets               SiteAsset[]
  generationSessions   GenerationSession[]
  aiCredentials        AiCredential[]
  gitHubConnection     GitHubConnection?

  @@index([userId, createdAt])
}

// Encrypted, server-side vault for user-supplied AI provider API keys.
// The raw key never leaves the server: generated sites call the platform proxy
// with `proxyToken`, and the proxy decrypts the matching key to call the
// provider. siteId is optional — null means an account-wide default key.
model AiCredential {
  id         String    @id @default(cuid())
  userId     String
  siteId     String?
  provider   String    @default("openai") // openai, anthropic, ...
  last4      String // for display, e.g. show "sk-…abcd" without the secret
  ciphertext String // base64 AES-256-GCM ciphertext of the API key
  iv         String // base64 nonce
  authTag    String // base64 GCM auth tag
  proxyToken String    @unique // opaque token embedded in the generated site
  revoked    Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  site       Site?     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, siteId])
  @@index([userId])
  @@index([siteId])
}

model SiteAsset {
  id          String   @id @default(cuid())
  siteId      String
  path        String
  contentType String
  content     Bytes
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, path])
  @@index([siteId])
}

// Encrypted GitHub OAuth token for a user/site. Tokens are encrypted with the
// same AES-256-GCM vault used for AI credentials and are never exposed to clients.
model GitHubConnection {
  id           String   @id @default(cuid())
  userId       String
  siteId       String   @unique
  accessToken  String // base64 AES-256-GCM ciphertext
  iv           String // base64 nonce
  authTag      String // base64 GCM auth tag
  scope        String // e.g. "repo"
  githubUserId String?
  githubLogin  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([userId])
}
